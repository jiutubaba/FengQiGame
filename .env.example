# 复制为 .env 后填写。正式域名使用 https://admin.example.com，本机使用 http://localhost。
DEPLOYMENT_MODE=docker
SITE_ADDRESS=https://admin.example.com
NODE_ENV=production
PORT=3000
TRUST_PROXY=1
COOKIE_SECURE=true

POSTGRES_DB=fengqi
POSTGRES_USER=fengqi
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgres://fengqi:replace-with-a-strong-database-password@db:5432/fengqi

SESSION_COOKIE_NAME=fq_session
SESSION_TTL_HOURS=12
ADMIN_USERNAME=风起
ADMIN_PASSWORD=replace-with-at-least-12-characters
ADMIN_DISPLAY_NAME=风起
PUBLIC_REGISTRATION=false
UPLOAD_MAX_MB=50
LOG_LEVEL=info
